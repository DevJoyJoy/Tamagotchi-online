      "type": "text",
      "x": 1114.6999219080733,
      "y": 588.9529195581648,
      "width": 414.7911827135334,
      "height": 71.83901092696655,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
