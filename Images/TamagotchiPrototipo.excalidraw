      "roundness": null,
      "seed": 883259802,
      "version": 1234,
      "versionNonce": 874655942,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780162117718,
      "link": null,
      "locked": false,
      "text": "Eu escolhi desenvolver um mini Tamagotchi online após a sugestão de um\namigo, eu queria desenvolver algo diferente e divertido para a atividade,\nque não apenas trouxesse um pouco dos meus gostos e personalidade\nmas que também fosse desafiador e diferente do que eu estou\ncostumada a produzir no desenvolvimento web.",
      "fontSize": 11.494241748314646,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Eu escolhi desenvolver um mini Tamagotchi online após a sugestão de um amigo, eu queria desenvolver algo diferente e divertido para a atividade, que não apenas trouxesse um pouco dos meus gostos e personalidade mas que também fosse desafiador e diferente do que eu estou costumada a produzir no desenvolvimento web.",
      "autoResize": false,
      "lineHeight": 1.25
    },
