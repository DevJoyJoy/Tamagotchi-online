    {
      "id": "jSml2NRZ_A_cOcra4baE5",
      "type": "text",
      "x": 1113.7129526785116,
      "y": 712.5984374533007,
      "width": 414.7911827135334,
      "height": 57.471208741573236,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
